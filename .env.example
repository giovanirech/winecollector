# PostgreSQL — used by the db service in docker-compose.yml
POSTGRES_USER=winecollector
POSTGRES_PASSWORD=changeme
POSTGRES_DB=winecollector

# Application database connection (asyncpg)
DATABASE_URL=postgresql+asyncpg://winecollector:changeme@localhost:5432/winecollector

# Authentication — generate with: openssl rand -hex 32
SECRET_KEY=changeme-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Image storage (relative to project root or absolute)
IMAGES_DIR=data/images

# Scraper configuration
SCRAPER_TIMEOUT=15.0
SCRAPER_USER_AGENT=WineCollector/1.0 (personal wine cellar manager)

# Runtime mode: development | production
ENVIRONMENT=development
